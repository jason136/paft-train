<mujoco model="mini_tars">
    <compiler angle="radian"/>

    <option gravity="0 0 -9.81" timestep="0.002">
        <flag contact="enable" override="enable"/>
    </option>

    <size nconmax="100" njmax="500"/>
    <option>
        <flag warmstart="enable"/>
    </option>

    <default>
        <geom type="box" density="500" rgba="0.7 0.7 0.7 1" solref="0.002 1" solimp="0.99 0.999 0.001"/>
        <joint type="hinge" limited="true" axis="0 1 0" damping="4.0" frictionloss="0.2" armature="0.0025"/>
        <position kp="50" kv="12"/>

        <default class="linear_slide">
            <!-- JQDML: ~5mm/s at typical operating force -->
            <joint type="slide" damping="3000.0" frictionloss="2.0" armature="0.5"/>
        </default>
    </default>

    <worldbody>
        <light diffuse=".7 .7 .7" pos="0 0 3" dir="0 0 -1"/>
        <!-- friction="sliding torsional rolling" -->
        <geom type="plane" size="5 5 0.1" rgba="0.9 0.9 0.9 1" friction="5.0 1.0 0.005"/>

        <!-- TARS body: 480mm tall, 214mm wide (arms + body), 54mm deep -->
        <body name="tars" pos="0 0 0.24">
            <joint type="free" damping="0"/>
            <!-- Torso: 1.0kg, COM at geometric center -->
            <inertial pos="0 0 0" mass="1.0" diaginertia="0.019 0.020 0.001"/>
            <geom name="body_center" size="0.0535 0.027 0.24" rgba="0.7 0.7 0.7 1" friction="5.0 1.0 0.005"/>
            <geom name="front_screen" type="box" size="0.0535 0.0002 0.03" pos="0 0.0271 0.144" rgba="0.05 0.05 0.05 1" contype="0" conaffinity="0" mass="0" group="1"/>
            <site name="imu_site" pos="0 0 0" size="0.01"/>

            <!-- Left arm: MG996R swing servo + linear shrug -->
            <body name="left_arm" pos="-0.0535 0 0.1185">
                <!-- MG996R: 11 kg·cm stall, 0.14s/60°, 180° range -->
                <joint name="left_swing" type="hinge" axis="1 0 0" limited="true" range="-1.5708 1.5708" damping="0.15" armature="0.01"/>
                <inertial pos="0 0 0" mass="0.02" diaginertia="0.0001 0.0001 0.0001"/>
                <body name="left_arm_segment" pos="0 0 0">
                    <!-- JQDML 10mm stroke, 188N max, 5mm/s -->
                    <joint name="left_shrug" class="linear_slide" axis="0 0 1" limited="true" range="-0.005 0.005"/>
                        <!-- Arm: 0.7kg, COM at arm center 0.1185m below pivot -->
                    <inertial pos="-0.02675 0 -0.1185" mass="0.7" diaginertia="0.0136 0.0136 0.00034"/>
                    <geom name="left_arm_geom" size="0.02675 0.027 0.24" pos="-0.02675 0 -0.1185" rgba="0.7 0.7 0.7 1" friction="5.0 1.0 0.005"/>
                </body>
            </body>

            <!-- Right arm: MG996R swing servo + linear shrug -->
            <body name="right_arm" pos="0.0535 0 0.1185">
                <joint name="right_swing" type="hinge" axis="1 0 0" limited="true" range="-1.5708 1.5708" damping="0.15" armature="0.01"/>
                <inertial pos="0 0 0" mass="0.02" diaginertia="0.0001 0.0001 0.0001"/>
                <body name="right_arm_segment" pos="0 0 0">
                    <!-- JQDML 10mm stroke, 188N max, 5mm/s -->
                    <joint name="right_shrug" class="linear_slide" axis="0 0 1" limited="true" range="-0.005 0.005"/>
                        <!-- Arm: 0.7kg, COM at arm center 0.1185m below pivot -->
                    <inertial pos="0.02675 0 -0.1185" mass="0.7" diaginertia="0.0136 0.0136 0.00034"/>
                    <geom name="right_arm_geom" size="0.02675 0.027 0.24" pos="0.02675 0 -0.1185" rgba="0.7 0.7 0.7 1" friction="5.0 1.0 0.005"/>
                </body>
            </body>
        </body>

        <geom name="target_arrow" type="box" size="0.1 0.002 0.002" pos="0 0 0.5" rgba="1 0 0 0.6" contype="0" conaffinity="0" mass="0" group="1"/>
        <camera name="track" mode="trackcom" pos="0 -0.6 1.0" xyaxes="1 0 0 0 1.2 1"/>
    </worldbody>

    <actuator>
        <!-- MG996R swing servos: 1.1 Nm stall torque (11 kg·cm at 6V) -->
        <position name="left_swing_servo" joint="left_swing" kp="15" kv="1.5" ctrllimited="true" ctrlrange="-1.5708 1.5708" forcerange="-1.1 1.1"/>
        <!-- JQDML linear actuator: 188N max, 5mm/s, 10mm stroke -->
        <position name="left_shrug_servo" joint="left_shrug" kp="5000" kv="500" ctrllimited="true" ctrlrange="-0.005 0.005" forcerange="-188 188"/>

        <!-- Right arm (symmetric) -->
        <position name="right_swing_servo" joint="right_swing" kp="15" kv="1.5" ctrllimited="true" ctrlrange="-1.5708 1.5708" forcerange="-1.1 1.1"/>
        <position name="right_shrug_servo" joint="right_shrug" kp="5000" kv="500" ctrllimited="true" ctrlrange="-0.005 0.005" forcerange="-188 188"/>
    </actuator>

    <sensor>
        <gyro name="body_gyro" site="imu_site"/>
        <accelerometer name="body_accel" site="imu_site"/>
    </sensor>
</mujoco>
